# INSTRUCTIONS: Copy this file to .env in the same directory and fill in the values. Only the first three are required.

JELLYFIN_URL=https://your.jellyfin.server
JELLYFIN_API_KEY=your_api_key_here
JELLYFIN_USER_ID=your_user_id_here

# This is optional but is needed if you want to sync from jellyfin on first launch. 
INITIAL_FULL_SYNC=true

# Optional server configuration. Defaults are usually fine for local development.

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:1420,http://localhost:5173

# Optional data directory overrides. Use either a directory or a full .db file path.
DATA_DIR=
FINLOAD_DATA_DIR=
DATABASE_PATH=
VITE_BACKEND_URL=http://127.0.0.1:8000
